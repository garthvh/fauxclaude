#!/usr/bin/env bash
# claude-local — run Claude Code against your local Ollama via FauxClaude (macOS/Linux).
# Starts FauxClaude in the background if it isn't already running, then launches claude.
#
#   ./claude-local                # interactive session
#   ./claude-local -p "fix bug"   # any claude args pass through
#
# Env overrides: SHIM_PORT, OLLAMA_URL, OLLAMA_MODEL, MODEL_MAP, NUM_CTX, MOCK
set -euo pipefail

SHIM_PORT="${SHIM_PORT:-11435}"
SHIM_URL="http://127.0.0.1:${SHIM_PORT}"
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! curl -sf --max-time 1 "${SHIM_URL}/health" > /dev/null 2>&1; then
  echo "[claude-local] starting FauxClaude on :${SHIM_PORT}..."
  # Every Claude tier routes to one local model (qwen3-vl: MoE, so fast, and it
  # also does vision + tool calls). Override OLLAMA_MODEL to change it, or set a
  # MODEL_MAP to split tiers across models if you keep more than one installed.
  PORT="$SHIM_PORT" \
    OLLAMA_MODEL="${OLLAMA_MODEL:-qwen3-vl:30b-a3b-instruct}" \
    nohup node "$DIR/server.mjs" >> "$DIR/shim.log" 2>&1 &
  for _ in $(seq 1 20); do
    curl -sf --max-time 1 "${SHIM_URL}/health" > /dev/null 2>&1 && break
    sleep 0.25
  done
fi

if [ "${MOCK:-0}" != "1" ] && ! curl -sf --max-time 2 "${OLLAMA_URL:-http://localhost:11434}/api/tags" > /dev/null 2>&1; then
  echo "[claude-local] WARNING: Ollama doesn't appear to be running (ollama serve)." >&2
fi

echo "[claude-local] dashboard: ${SHIM_URL}/"
# No credential env vars: your claude.ai login rides through to the shim
# (which ignores auth). Not logged in? export ANTHROPIC_AUTH_TOKEN=anything.
unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN
export ANTHROPIC_BASE_URL="$SHIM_URL"
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export MAX_THINKING_TOKENS="${MAX_THINKING_TOKENS:-1024}"   # low thinking for speed

# This launcher is the FAST path — Haiku (mapped to the small model) + low thinking
# for quick/scripted local sessions. Pin a different model with CLAUDE_LOCAL_MODEL.
# (For quality, use the app's "Run Claude Code in Terminal", which uses your own
# Claude Code model + thinking settings.)
exec claude --model "${CLAUDE_LOCAL_MODEL:-haiku}" "$@"
